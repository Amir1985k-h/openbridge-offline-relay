# ====================== OpenBridge Gateway Server ======================

# ==================== Server Basic Config ====================
PORT=3000
NODE_ENV=development

# ==================== SECURITY - VERY IMPORTANT ====================
# این کلید باید خیلی قوی و تصادفی باشه (حداقل ۳۲-۶۴ کاراکتر)
SMS_RELAY_SECRET=your_super_long_random_secret_key_here_please_change_this_in_production_2026

# ==================== RPC Endpoints ====================
ETH_RPC_URL=https://eth.llamarpc.com
# ETH_RPC_URL2=https://rpc.ankr.com/eth
# ETH_RPC_URL3=https://cloudflare-eth.com

POLYGON_RPC_URL=https://polygon.llamarpc.com
# POLYGON_RPC_URL2=https://rpc.ankr.com/polygon

# ==================== Rate Limiting ====================
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW_MINUTES=15

# ==================== Allowed Phone Numbers (اختیاری برای MVP) ====================
# شماره‌هایی که اجازه ارسال SMS دارند (با کاما جدا کن)
ALLOWED_PHONE_NUMBERS=+989123456789,+989876543210

# ==================== Logging ====================
LOG_LEVEL=info

# ==================== JWT (فعلاً استفاده نمی‌شود - برای آینده) ====================
JWT_SECRET=your-super-secret-jwt-key-here-change-it-immediately

# ==================== Future Configs (بعداً استفاده می‌شود) ====================
# DATABASE_URL=postgresql://...
# ENCRYPTION_KEY=...
