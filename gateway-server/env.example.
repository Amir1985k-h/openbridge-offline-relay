# ====================== OpenBridge Gateway Server ======================

# ==================== Server Config ====================
PORT=3000
NODE_ENV=development

# ==================== Security ====================
# این کلید باید خیلی طولانی و تصادفی باشه (حداقل ۳۲ کاراکتر)
SMS_RELAY_SECRET=your_super_long_random_secret_key_here_change_in_production

# لیست شماره‌هایی که اجازه ارسال دارن (برای امنیت بیشتر در MVP)
ALLOWED_PHONE_NUMBERS=+989123456789,+989876543210

# ==================== RPC Endpoints ====================
# Ethereum
ETH_RPC_URL=https://eth.llamarpc.com
# ETH_RPC_URL2=https://rpc.ankr.com/eth
# ETH_RPC_URL3=https://cloudflare-eth.com

# Polygon
POLYGON_RPC_URL=https://polygon.llamarpc.com
# POLYGON_RPC_URL2=https://rpc.ankr.com/polygon

# ==================== Rate Limiting ====================
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW_MINUTES=15

# ==================== Logging & Monitoring ====================
LOG_LEVEL=info

# ==================== Database (بعداً اضافه می‌شود) ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/openbridge

# ==================== Advanced Security (بعداً) ====================
